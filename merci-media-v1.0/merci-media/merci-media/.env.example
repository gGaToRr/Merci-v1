# ╔══════════════════════════════════════════════════════════════════════════╗
# ║          Merci Media — Configuration                                     ║
# ║  Copiez ce fichier en .env et renseignez vos valeurs                     ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Sécurité ──────────────────────────────────────────────────────────────
# Clé JWT secrète (générer : python3 -c "import secrets; print(secrets.token_hex(64))")
JWT_SECRET_KEY=CHANGEZ_MOI_AVEC_UNE_CLE_ALEATOIRE_LONGUE

# Compte administrateur (créé automatiquement au 1er démarrage)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_FORT

# ── Deezer ────────────────────────────────────────────────────────────────
# Cookie ARL de votre compte Deezer (récupérable depuis les DevTools de deezer.com)
# Application > Cookies > deezer.com > arl
DEEZER_COOKIE_ARL=VOTRE_ARL_ICI

# ── TMDB (films & séries) ────────────────────────────────────────────────
# Clé API gratuite sur https://www.themoviedb.org/settings/api
TMDB_API_KEY=VOTRE_CLE_TMDB_ICI

# ── Port d'accès ─────────────────────────────────────────────────────────
# L'application sera accessible sur http://localhost:PORT
PORT=8080

# ── Chemin vers votre collection de films (optionnel) ────────────────────
# Dossier local contenant vos films (.mp4, .mkv...)
# MOVIES_PATH=/chemin/vers/vos/films
